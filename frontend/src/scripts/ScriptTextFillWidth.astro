<script>
  function adjustFontSize() {
    const textFillWidthElements = document.querySelectorAll(
      "[data-text-fill-width]",
    ) as NodeListOf<HTMLElement>;
    if (textFillWidthElements.length === 0) return;

    for (const textFillWidthElement of textFillWidthElements) {
      adjustFontSizeForElement(textFillWidthElement);
    }

    function adjustFontSizeForElement(text: HTMLElement) {
      const section = text.parentElement;
      if (!section) return;

      text.style.fontSize = "1px";
      text.style.textTransform = "uppercase";

      const sectionWidth = section.clientWidth;
      text.style.whiteSpace = "nowrap";

      const referenceFontSize = 100;
      text.style.fontSize = `${referenceFontSize}px`;
      text.style.display = "inline-block";

      const textWidth = text.getBoundingClientRect().width;
      const newFontSize = (sectionWidth / textWidth) * referenceFontSize;
      text.style.fontSize = `${newFontSize}px`;
      text.style.lineHeight = "0.8";
      text.style.display = "";
    }
  }

  window.addEventListener("resize", adjustFontSize);
  document.addEventListener("DOMContentLoaded", adjustFontSize);
  document.fonts.ready.then(adjustFontSize);
  adjustFontSize();
</script>
