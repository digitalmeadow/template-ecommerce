<script is:inline>
  function adjustFontSize() {
    const textFillWidthElements = document.querySelectorAll("[data-text-fill-width]");
    if (textFillWidthElements.length === 0) return;

    for (const textFillWidthElement of textFillWidthElements) {
      adjustFontSizeForElement(textFillWidthElement);
    }

    function adjustFontSizeForElement(textElement) {
      const section = textElement.parentElement;
      if (!section) return;

      textElement.style.fontSize = "1px";
      textElement.style.textTransform = "uppercase";

      const sectionWidth = section.clientWidth;
      textElement.style.whiteSpace = "nowrap";

      const referenceFontSize = 100;
      textElement.style.fontSize = `${referenceFontSize}px`;
      textElement.style.display = "inline-block";

      const textWidth = textElement.getBoundingClientRect().width;
      const newFontSize = (sectionWidth / textWidth) * referenceFontSize;
      textElement.style.fontSize = `${newFontSize}px`;
      textElement.style.lineHeight = "0.8";
      textElement.style.display = "";
    }
  }

  window.addEventListener("resize", adjustFontSize);
  document.addEventListener("DOMContentLoaded", adjustFontSize);
  document.fonts.ready.then(adjustFontSize);
  adjustFontSize();
</script>
