---
import "../styles/reset.css";
import "../styles/base.css";
import "../styles/colors.css";
import "../styles/spacing.css";
import "../styles/typography.css";
import "../styles/elements.css";
import "../styles/animations.css";
import "../styles/aspects.css";
import "../styles/fonts.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Grid from "../dev/Grid.astro";
import Meta from "../meta/Meta.astro";
import type { MetaFragment } from "sanity/generated/graphql";
import { WEBSITE_URL } from "astro:env/client";
import Cart from "../components/cart/Cart.astro";
import LocaleSelector from "../components/LocaleSelector.astro";
import { getLocaleFromPath, LOCALE_CONFIG } from "../lib/shopify/locale";

interface Props {
  metaData: MetaFragment | null | undefined;
}

const { metaData }: Props = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, WEBSITE_URL).href;
const currentLocale = getLocaleFromPath(Astro.url.pathname);
const localeConfig = LOCALE_CONFIG[currentLocale];
---

<html
  lang={currentLocale}
  data-locale={currentLocale}
  data-currency={localeConfig.currency}
  data-country={localeConfig.country}
  data-language={localeConfig.language}
  data-path-prefix={localeConfig.pathPrefix ?? "/"}
>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme" content="#000000" />
    <meta name="generator" content={Astro.generator} />
    <title>{metaData?.title}</title>
    <Meta metaData={metaData} />
    <link rel="canonical" href={canonicalUrl} />
  </head>
  <body>
    <Header />
    <LocaleSelector />
    <Cart />
    <main>
      <slot />
    </main>
    <Footer />
    <Grid />
  </body>
</html>
