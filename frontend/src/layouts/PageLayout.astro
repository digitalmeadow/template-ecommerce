---
import "@styles/reset.css";
import "@styles/base.css";
import "@styles/colors.css";
import "@styles/spacing.css";
import "@styles/typography.css";
import "@styles/elements.css";
import "@styles/animations.css";
import "@styles/aspects.css";
import "@styles/fonts.css";

import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Grid from "@dev/Grid.astro";
import Meta from "@meta/Meta.astro";
import type { MetaFragment } from "sanity/generated/graphql";
import { WEBSITE_URL } from "astro:env/client";
import { getLocaleFromPath, LOCALE_CONFIG } from "@lib/shopify/locale";
import CookiesBanner from "@components/CookiesBanner.astro";
import ScriptSpacing from "../scripts/ScriptSpacing.astro";
import Cart from "@components/cart/Cart.astro";
import ScriptTextFillWidth from "../scripts/ScriptTextFillWidth.astro";

interface Props {
  metaData: MetaFragment | null | undefined;
}

const { metaData }: Props = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, WEBSITE_URL).href;
const currentLocale = getLocaleFromPath(Astro.url.pathname);
const localeConfig = LOCALE_CONFIG[currentLocale];
---

<html
  lang={currentLocale}
  data-locale={currentLocale}
  data-currency={localeConfig.currency}
  data-country={localeConfig.country}
  data-language={localeConfig.language}
  data-path-prefix={localeConfig.pathPrefix ?? "/"}
>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme" content="#000000" />
    <meta name="generator" content={Astro.generator} />
    <title>{metaData?.title}</title>
    <Meta metaData={metaData} />
    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="preload"
      href="/fonts/BIZUDMincho-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <ScriptSpacing />
    <ScriptTextFillWidth />
  </head>
  <body>
    <div class="header">
      <Header />
    </div>

    <Cart />

    <main>
      <slot />
    </main>

    <CookiesBanner />
    <Footer />

    <Grid />
  </body>
</html>

<style>
  body {
    display: grid;
  }

  body > .header {
    grid-area: 1 / 1 / 2 / 2;
  }

  body > main {
    grid-area: 1 / 1 / 2 / 2;
  }
</style>
