---
import "@styles/reset.css";
import "@styles/base.css";
import "@styles/colors.css";
import "@styles/spacing.css";
import "@styles/text.css";
import "@styles/elements.css";
import "@styles/animations.css";
import "@styles/aspects.css";
import "@styles/fonts.css";

import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Grid from "@dev/Grid.astro";
import Meta from "@meta/Meta.astro";
import type { MetaFragment } from "sanity/generated/graphql";
import { getLocaleFromPath, LOCALE_CONFIG } from "@lib/shopify/locale";
import CookiesBanner from "@components/CookiesBanner.astro";
import ScriptSpacing from "../scripts/ScriptSpacing.astro";
import Cart from "@components/cart/Cart.astro";
import ScriptTextFillWidth from "../scripts/ScriptTextFillWidth.astro";
import { sanityClient } from "sanity/client";
import { metaSettingsQuery } from "sanity/queries/metaSettings";

interface Props {
  metaData: MetaFragment | null | undefined;
}

const { metaData }: Props = Astro.props;

const currentLocale = getLocaleFromPath(Astro.url.pathname);
const localeConfig = LOCALE_CONFIG[currentLocale];

const metaSettingsQueryResult = await sanityClient.request(metaSettingsQuery);
const metaSettingsData = metaSettingsQueryResult?.allMetaSettings?.[0];
---

<html
  lang={currentLocale}
  data-locale={currentLocale}
  data-currency={localeConfig.currency}
  data-country={localeConfig.country}
  data-language={localeConfig.language}
  data-path-prefix={localeConfig.pathPrefix ?? "/"}
>
  <head>
    <meta charset="utf-8" />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Digital Meadow" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme" content="#F6F2E5" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <Meta metaData={metaData} metaSettingsData={metaSettingsData} />
    <link
      rel="preload"
      href="/fonts/BIZUDMincho-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <ScriptSpacing />
    <ScriptTextFillWidth />
  </head>
  <body>
    <div class="header">
      <Header />
    </div>

    <Cart />

    <main>
      <slot />
    </main>

    <CookiesBanner />
    <Footer />

    <Grid />
  </body>
</html>

<style>
  body {
    display: grid;
  }

  body > .header {
    grid-area: 1 / 1 / 2 / 2;
  }

  body > main {
    grid-area: 1 / 1 / 2 / 2;
  }
</style>
