---
import type { SanityImageFragment } from "../sanity/generated/graphql";

interface Props {
  imageData: SanityImageFragment | null | undefined;
  layout?: "width" | "height" | "cover" | "contain";
  sizes?: [number, number, number];
  loading?: "lazy" | "eager";
  mediaId?: string | null;
}

const {
  imageData,
  layout = "width",
  sizes = [100, 100, 100],
  loading = "lazy",
  mediaId,
}: Props = Astro.props;

function getSanityImageProps({
  sanityImage,
  sizes,
}: {
  sanityImage: SanityImageFragment | null | undefined;
  sizes: [number, number, number];
}) {
  if (!sanityImage?.asset) return {};

  const dpr = typeof window !== "undefined" ? window.devicePixelRatio : 2;
  const [desktop, tablet, mobile] = sizes;
  const sizesAttr = `(min-width: 800px) ${desktop}vw, (min-width: 500px) ${tablet}vw, ${mobile}vw`;
  const widths = [400, 600, 800, 1000, 1400, 1800, 2200];

  const srcset = widths
    .map((w) => {
      let url = `${sanityImage.asset?.url}?w=${w}&fit=max&auto=format`;
      if (dpr) url += `&dpr=${dpr}`;
      return `${url} ${w}w`;
    })
    .join(", ");

  const fallbackWidth = 1000;
  const src = `${sanityImage.asset?.url}?w=${fallbackWidth}&fit=max&dpr=${dpr}&auto=format`;

  return {
    src,
    srcset,
    sizes: sizesAttr,
  };
}

const altText = imageData?.asset?.altText ?? "";
const blurhashSrc = imageData?.asset?.metadata?.lqip;
---

<div class={`sanity-image layout-${layout}`}>
  <img class="blurhash" src={blurhashSrc} alt="" loading="eager" />

  <img
    class={`image layout-${layout}`}
    data-media-id={mediaId}
    {...getSanityImageProps({ sanityImage: imageData, sizes })}
    alt={altText}
    loading={loading}
    onload="this.classList.add('loaded')"
  />
</div>

<style>
  .sanity-image {
    position: relative;
    overflow: hidden;
  }

  .blurhash {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image {
    position: relative;
    opacity: 0;
    transition: opacity var(--transition-media-load);
  }

  .image.loaded {
    opacity: var(--media-opacity, 1);
  }

  .layout-width {
    width: 100%;
  }

  .layout-height {
    height: 100%;
  }

  .layout-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .layout-contain {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>
