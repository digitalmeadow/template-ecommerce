---
import type { MetaFragment } from "sanity/generated/graphql";

interface Props {
  metaData: MetaFragment | null | undefined;
}

const { metaData }: Props = Astro.props;
---

<meta name="description" content={metaData?.description} />

<meta property="og:title" content={metaData?.title ?? ""} />
<meta property="og:description" content={metaData?.description ?? ""} />
<meta property="og:image" content={metaData?.image?.asset?.url} />
