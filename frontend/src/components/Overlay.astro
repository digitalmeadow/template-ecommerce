<overlay-root {...Astro.props}>
  <div class="overlay-backdrop"></div>
  <slot />
</overlay-root>

<script>
  export class OverlayElement extends HTMLElement {
    private backdrop!: HTMLElement;
    private closeButton!: HTMLElement | null;
    private panel!: HTMLElement | null;
    private previouslyFocused: HTMLElement | null = null;

    connectedCallback() {
      this.backdrop = this.querySelector(".overlay-backdrop")!;
      this.closeButton = this.querySelector(".overlay-close");

      const slot = this.querySelector("slot");
      if (slot) {
        const assignedElements = slot.assignedElements();
        if (assignedElements.length > 0) {
          this.panel = assignedElements[0] as HTMLElement;
        }
      }

      if (!this.panel) {
        this.panel = Array.from(this.children).find(
          (el) => !el.classList.contains("overlay-backdrop"),
        ) as HTMLElement;
      }

      if (this.panel) {
        this.panel.setAttribute("role", "dialog");
        this.panel.setAttribute("aria-modal", "true");
        this.panel.setAttribute("tabindex", "-1");
      }

      this.backdrop.addEventListener("click", () => this.close());
      if (this.closeButton) this.closeButton.addEventListener("click", () => this.close());

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && this.hasAttribute("data-open")) {
          this.close();
        }
      });
    }

    open() {
      this.previouslyFocused = document.activeElement as HTMLElement;
      this.setAttribute("data-open", "");
      document.body.style.overflow = "hidden";

      requestAnimationFrame(() => {
        this.panel?.focus();
      });

      this.dispatchEvent(new CustomEvent("overlay:open"));
    }

    close() {
      this.removeAttribute("data-open");
      document.body.style.overflow = "";

      if (this.previouslyFocused) {
        this.previouslyFocused.focus();
      }

      this.dispatchEvent(new CustomEvent("overlay:close"));
    }

    toggle() {
      if (this.hasAttribute("data-open")) {
        this.close();
      } else {
        this.open();
      }
    }
  }

  customElements.define("overlay-root", OverlayElement);
</script>

<style>
  overlay-root {
    position: fixed;
    inset: 0;
    z-index: 10;
    display: none;
    pointer-events: none;
  }

  overlay-root[data-open] {
    display: block;
    pointer-events: auto;
  }

  .overlay-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  overlay-root[data-open] .overlay-backdrop {
    opacity: 1;
  }
</style>
