<quantity-selector>
  <button type="button" data-decrease-button aria-label="Decrease quantity">−</button>
  <input
    type="number"
    inputmode="numeric"
    min="1"
    step="1"
    pattern="[0-9]+"
    data-input
    aria-label="Quantity"
  />
  <button type="button" data-increase-button aria-label="Increase quantity">+</button>
</quantity-selector>

<script>
  import { z } from "astro/zod";

  export type QuantityChangedEvent = CustomEvent<{ value: number }>;

  export class QuantitySelectorElement extends HTMLElement {
    private input!: HTMLInputElement;
    private decreaseButton!: HTMLButtonElement;
    private increaseButton!: HTMLButtonElement;
    private value!: number;
    private min!: number;
    private max!: number;

    connectedCallback() {
      this.input = this.querySelector("[data-input]")!;
      this.decreaseButton = this.querySelector("[data-decrease-button]")!;
      this.increaseButton = this.querySelector("[data-increase-button]")!;

      this.min = Math.max(Number(this.getAttribute("min")) || 1, 1);
      this.max = Number(this.getAttribute("max")) || Infinity;
      this.value = Math.max(
        this.min,
        Math.min(this.max, Number(this.getAttribute("initial")) || 1)
      );

      this.render();

      this.decreaseButton.addEventListener("click", this.decrease);
      this.increaseButton.addEventListener("click", this.increase);
      this.input.addEventListener("change", this.onInputChange);
    }

    disconnectedCallback() {
      this.decreaseButton.removeEventListener("click", this.decrease);
      this.increaseButton.removeEventListener("click", this.increase);
      this.input.removeEventListener("change", this.onInputChange);
    }

    render() {
      this.input.value = String(this.value);
      this.input.min = String(this.min);
      if (this.max !== Infinity) {
        this.input.max = String(this.max);
      }
      this.decreaseButton.disabled = this.value <= this.min;
      this.increaseButton.disabled = this.value >= this.max;
    }

    setUpdatingState(updating: boolean) {
      if (updating) {
        this.setAttribute("state", "updating");
        this.input.setAttribute("aria-busy", "true");
        this.decreaseButton.disabled = true;
        this.increaseButton.disabled = true;
        this.input.disabled = true;
      } else {
        this.removeAttribute("state");
        this.input.removeAttribute("aria-busy");
        this.input.disabled = false;
        this.render();
      }
    }

    emitChangeEvent() {
      this.dispatchEvent(
        new CustomEvent("quantity-selector:quantity-changed", {
          detail: { value: this.value },
          bubbles: true,
        })
      );
    }

    decrease = (event: MouseEvent) => {
      event.preventDefault();
      if (this.value > this.min) {
        this.value--;
        this.render();
        this.emitChangeEvent();
      }
    };

    increase = (event: MouseEvent) => {
      event.preventDefault();
      if (this.value < this.max) {
        this.value++;
        this.render();
        this.emitChangeEvent();
      }
    };

    onInputChange = (_e: Event) => {
      const quantitySchema = z.coerce.number().int().positive().min(this.min).max(this.max);
      const result = quantitySchema.safeParse(this.input.value);

      if (result.success) {
        const next = result.data;
        if (next !== this.value) {
          this.value = next;
          this.render();
          this.emitChangeEvent();
        }
      } else {
        this.render();
      }
    };
  }

  customElements.define("quantity-selector", QuantitySelectorElement);
</script>

<style>
  button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  quantity-selector[state="updating"] input,
  quantity-selector[state="updating"] button {
    opacity: 0.5;
  }
</style>
