<button class="cart-button" data-cart-button aria-label="Toggle cart">
  Cart<span data-cart-count></span>
</button>

<script>
  import { $cartCount, loadCart } from "@stores/cart";
  import { setCartOpen } from "@stores/ui";

  const button = document.querySelector("[data-cart-button]") as HTMLButtonElement;
  const cartCountElement = document.querySelector("[data-cart-count]") as HTMLElement;

  $cartCount.subscribe((count: number) => {
    cartCountElement.textContent = `(${count})`;
  });

  button.addEventListener("click", () => {
    setCartOpen(true);
  });

  loadCart();
</script>

<style>
  .cart-button {
    display: inline-flex;
    align-items: center;
    gap: 1ch;
    justify-self: end;
  }
</style>
