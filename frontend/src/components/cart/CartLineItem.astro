---
import PriceDisplay from "@blocks/PriceDisplay.astro";
import QuantitySelector from "@blocks/QuantitySelector.astro";
---

<cart-line-item>
  <div class="cart-line-item">
    <a data-link class="thumbnail">
      <img data-image alt="" />
    </a>

    <div class="info">
      <a data-link class="text-link-wrapper">
        <div>
          <span class="product-title" data-title></span>
          <span class="variant-title" data-variant-title></span>
        </div>
      </a>

      <div class="inventory">
        <QuantitySelector data-quantity-selector />
        <button
          class="text-link underline-color-orange remove-button"
          type="button"
          data-remove-button
          aria-label="Remove item from cart"
        >
          Remove
        </button>
      </div>

      <div class="prices">
        <div style="display: none;" data-compare-at-wrapper>
          <PriceDisplay variant="compare-at" data-compare-at-price />
        </div>
        <PriceDisplay data-price />
      </div>
    </div>
  </div>
</cart-line-item>

<script>
  import { resolveSanityHref } from "@lib/sanity/links";
  import { getCurrency } from "@lib/shopify/locale";
  import { updateLineQuantity, removeLine } from "@stores/cart";
  import type { QuantitySelectorElement } from "@blocks/QuantitySelector.astro.0.mts";
  import type { PriceDisplayElement } from "@blocks/PriceDisplay.astro.0.mts";
  import type { CartLineFragment } from "shopify/generated/graphql";

  export class CartLineItemElement extends HTMLElement {
    linkElements: NodeListOf<HTMLAnchorElement> | undefined;
    imageElement!: HTMLImageElement;
    titleElement!: HTMLElement;
    variantTitleElement!: HTMLElement;
    removeButton!: HTMLButtonElement;
    quantitySelector!: QuantitySelectorElement;

    priceDisplay!: PriceDisplayElement;
    compareAtWrapper!: HTMLElement;
    compareAtDisplay!: PriceDisplayElement;

    line?: CartLineFragment;

    init(line: CartLineFragment) {
      this.line = line;
      this.render();
    }

    connectedCallback() {
      this.linkElements = this.querySelectorAll("[data-link]");
      this.imageElement = this.querySelector("[data-image]")!;
      this.titleElement = this.querySelector("[data-title]")!;
      this.variantTitleElement = this.querySelector("[data-variant-title]")!;
      this.removeButton = this.querySelector("[data-remove-button]")!;
      this.quantitySelector = this.querySelector("quantity-selector")!;

      this.priceDisplay = this.querySelector("[data-price]")!;
      this.compareAtWrapper = this.querySelector("[data-compare-at-wrapper]")!;
      this.compareAtDisplay = this.querySelector("[data-compare-at-price]")!;

      this.removeButton.addEventListener("click", this.handleRemove);
      this.addEventListener("quantity-selector:quantity-changed", this.handleQuantityChange);
    }

    disconnectedCallback() {
      this.removeButton.removeEventListener("click", this.handleRemove);
      this.removeEventListener("quantity-selector:quantity-changed", this.handleQuantityChange);
    }

    setRemoving(isRemoving: boolean) {
      if (isRemoving) {
        this.setAttribute("data-state", "removing");
        this.removeButton.textContent = "Removing";
        this.removeButton.disabled = true;
      } else {
        this.removeAttribute("data-state");
        this.removeButton.textContent = "Remove";
        this.removeButton.disabled = false;
      }
    }

    private render() {
      if (!this.line) return;

      const { merchandise, quantity, cost, id } = this.line;
      const { product, title: variantTitle, compareAtPrice, image: variantImage } = merchandise;

      this.dataset.lineId = id;

      const href = resolveSanityHref("product", product.handle);
      for (const linkElement of this.linkElements!) {
        linkElement.href = href;
      }

      this.titleElement.textContent = product.title;
      this.variantTitleElement.textContent = variantTitle;

      const isSingleDefaultVariant =
        variantTitle === "Default Title" && product.variants?.edges?.length === 1;
      this.dataset.singleDefaultVariant = String(isSingleDefaultVariant);

      const imageUrl = variantImage?.url ?? product.variants?.edges?.[0]?.node?.image?.url;
      if (imageUrl) {
        this.imageElement.src = `${imageUrl}?w=120&h=120&fit=crop&auto=format`;
        this.imageElement.dataset.loaded = "true";
      }

      this.quantitySelector.setAttribute("initial", String(quantity));

      this.priceDisplay.setAttribute("amount", String(cost.totalAmount.amount ?? 0));
      this.priceDisplay.setAttribute("currency", cost.totalAmount.currencyCode ?? getCurrency());

      if (compareAtPrice) {
        const compareAtTotal = Number(compareAtPrice.amount) * quantity;
        this.compareAtDisplay.setAttribute("amount", String(compareAtTotal));
        this.compareAtDisplay.setAttribute(
          "currency",
          compareAtPrice.currencyCode ?? getCurrency(),
        );
        this.compareAtWrapper.style.display = "";
      } else {
        this.compareAtWrapper.style.display = "none";
      }
    }

    private handleRemove = async () => {
      if (!this.line) return;

      this.setRemoving(true);
      document.body.style.cursor = "wait";

      try {
        await removeLine(this.line.id);
      } catch (error) {
        console.error("Failed to remove cart line", error);
        this.setRemoving(false);
      } finally {
        document.body.style.cursor = "";
      }
    };

    private handleQuantityChange = async (e: Event) => {
      const event = e as CustomEvent<{ value: number }>;
      const quantitySelectorElement = event.target as QuantitySelectorElement;

      if (!this.line) return;

      const newQuantity = event.detail.value;

      quantitySelectorElement.setAttribute("data-state", "updating");
      document.body.style.cursor = "wait";

      try {
        await updateLineQuantity(this.line.id, newQuantity);
      } catch (error) {
        console.error("Failed to update cart quantity", error);
      } finally {
        document.body.style.cursor = "";
        quantitySelectorElement.removeAttribute("data-state");
      }
    };
  }

  customElements.define("cart-line-item", CartLineItemElement);
</script>

<style>
  cart-line-item {
    display: block;
    width: 100%;
  }

  .cart-line-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--gutter);
  }

  .thumbnail {
    width: 64px;
    height: 64px;
    object-fit: cover;
    background-color: var(--color-text);
  }

  [data-image] {
    opacity: 0;
    transition: opacity var(--transition-media-load);
  }

  [data-image][data-loaded]:not([data-loaded="false"]) {
    opacity: 1;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: var(--s4);
  }

  cart-line-item[data-single-default-variant]:not([data-single-default-variant="false"])
    .variant-title {
    display: none;
  }

  .inventory {
    display: flex;
    align-items: center;
    gap: var(--s16);
    flex-wrap: wrap;
  }

  .remove-button {
    align-self: start;
  }

  cart-line-item[data-state="removing"] {
    opacity: 0.5;
    pointer-events: none;
  }
</style>
