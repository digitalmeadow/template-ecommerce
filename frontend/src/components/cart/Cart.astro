---
import PriceDisplay from "@blocks/PriceDisplay.astro";
import QuantitySelector from "@blocks/QuantitySelector.astro";
import Overlay from "@layouts/Overlay.astro";
import CartLineItem from "./CartLineItem.astro";
import { sanityClient } from "sanity/client";
import { cartQuery } from "sanity/queries/cart";
import PortableText from "@fields/PortableText.astro";

const cartQueryQuery = await sanityClient.request(cartQuery);
const cartData = cartQueryQuery.allCart[0];
---

<Overlay id="cart" layout="right">
  <div class="header" slot="header">
    <h2>Your Cart <span data-cart-count></span></h2>
  </div>

  <cart-root slot="content">
    <!-- BUG: Astro dedup fails to mount native web components when within <template> tags -->
    <div style="display: none">
      <QuantitySelector />
      <PriceDisplay />
      <CartLineItem />
    </div>

    <template data-cart-line-template>
      <li>
        <CartLineItem />
      </li>
    </template>

    <div class="cart-content">
      <div class="empty-message">
        <PortableText value={cartData.emptyMessageRaw} />
      </div>

      <ul class="cart-line-items" data-cart-line-items></ul>

      <div data-cart-total>
        <span>Total:&nbsp;<PriceDisplay /></span>
      </div>

      <div class="footer">
        <p data-cart-note>
          <PortableText value={cartData.noteRaw} />
        </p>

        <button class="text-link checkout-button" data-cart-checkout-button>Checkout</button>
      </div>
    </div>
  </cart-root>
</Overlay>

<script>
  import { shopifyClient } from "shopify/client";
  import { cartByIdQuery } from "shopify/queries/cart";
  import { cartLinesUpdateMutation, cartLinesRemoveMutation } from "shopify/mutations/cart";
  import type { CartFragment } from "shopify/generated/graphql";
  import {
    CART_ID_STORAGE_KEY_SUFFIX,
    CART_DATA_STORAGE_KEY_SUFFIX,
    getStorageKey,
  } from "@lib/shopify/cart";
  import { getCountryCode } from "@lib/shopify/locale";
  import type {
    QuantitySelectorElement,
    EventQuantityChanged,
  } from "@blocks/QuantitySelector.astro.0.mts";
  import type { CartLineItemElement, CartLineRemoveEvent } from "./CartLineItem.astro.0.mts";

  export type EventCartUpdatedDetail = {
    count: number;
  };
  export type EventCartUpdated = CustomEvent<EventCartUpdatedDetail>;

  class CartRootElement extends HTMLElement {
    private lineItemsContainer!: HTMLUListElement;
    private checkoutButton!: HTMLButtonElement;
    private totalPriceDisplay!: HTMLElement;
    private itemTemplate!: HTMLTemplateElement;

    private cart: CartFragment | null = null;
    private mutationQueue: Promise<void> = Promise.resolve();

    private get cartId() {
      const key = getStorageKey(CART_ID_STORAGE_KEY_SUFFIX);
      return localStorage.getItem(key);
    }

    connectedCallback() {
      this.lineItemsContainer = this.querySelector("[data-cart-line-items]")!;
      this.totalPriceDisplay = this.querySelector("[data-cart-total] price-display")!;
      this.checkoutButton = this.querySelector("[data-cart-checkout-button]")!;
      this.itemTemplate = this.querySelector("[data-cart-line-template]")!;

      this.checkoutButton.addEventListener("click", this.onCheckoutClick);
      this.addEventListener("quantity-selector:quantity-changed", this.onQuantityChange);
      this.addEventListener("cart-line:remove", this.onLineRemove);

      document.addEventListener("product:add-to-cart", this.onProductAdded);

      this.loadCart();
    }

    disconnectedCallback() {
      this.checkoutButton.removeEventListener("click", this.onCheckoutClick);
      this.removeEventListener("quantity-selector:quantity-changed", this.onQuantityChange);
      this.removeEventListener("cart-line:remove", this.onLineRemove);
      document.removeEventListener("product:add-to-cart", this.onProductAdded);
    }

    onCheckoutClick = (_event: MouseEvent) => {
      if (this.cart?.checkoutUrl) {
        window.location.href = this.cart.checkoutUrl;
      }
    };

    onProductAdded = async () => {
      await this.mutationQueue;
      await this.loadCart();
    };

    onQuantityChange = async (e: Event) => {
      const event = e as EventQuantityChanged;
      const quantitySelectorElement = event.target as QuantitySelectorElement;

      const lineItemEl = quantitySelectorElement.closest("cart-line-item") as CartLineItemElement;
      if (!lineItemEl || !lineItemEl.line) return;

      const lineId = lineItemEl.line.id;
      const newQuantity = event.detail.value;

      console.log(
        "Quantity changed: ",
        newQuantity,
        "Quantity selector current value: ",
        quantitySelectorElement.value,
        "Line item quantity: ",
        lineItemEl.line.quantity,
      );

      const cartId = this.cartId;
      if (!cartId) return;

      quantitySelectorElement.setUpdatingState(true);

      document.body.style.cursor = "wait";

      this.mutationQueue = this.mutationQueue.then(async () => {
        try {
          await shopifyClient.request(cartLinesUpdateMutation, {
            cartId,
            lines: [{ id: lineId, quantity: newQuantity }],
            countryCode: getCountryCode(),
          });
          await this.loadCart(true);
        } catch (error) {
          console.error("Failed to update cart quantity", error);
        } finally {
          document.body.style.cursor = "";
        }
      });
      await this.mutationQueue;
    };

    onLineRemove = async (e: Event) => {
      const event = e as CartLineRemoveEvent;
      const { lineId } = event.detail;
      const lineItemEl = event.target as CartLineItemElement;

      const cartId = this.cartId;
      if (!cartId) return;

      lineItemEl?.setRemoving(true);

      document.body.style.cursor = "wait";

      this.mutationQueue = this.mutationQueue.then(async () => {
        try {
          await shopifyClient.request(cartLinesRemoveMutation, {
            cartId,
            countryCode: getCountryCode(),
            lineIds: [lineId],
          });
          await this.loadCart(true);
        } catch (error) {
          console.error("Failed to remove cart line", error);
        } finally {
          document.body.style.cursor = "";
        }
      });
      await this.mutationQueue;
    };

    async loadCart(skipCache = false) {
      const cartIdKey = getStorageKey(CART_ID_STORAGE_KEY_SUFFIX);
      const cartDataKey = getStorageKey(CART_DATA_STORAGE_KEY_SUFFIX);

      const cartId = localStorage.getItem(cartIdKey);
      if (!cartId) {
        this.renderEmpty();
        return;
      }

      if (!skipCache) {
        const cached = localStorage.getItem(cartDataKey);
        if (cached) {
          try {
            this.cart = JSON.parse(cached) as CartFragment;
            this.renderCart();
          } catch (e) {
            console.error("Failed to parse cached cart", e);
            localStorage.removeItem(cartDataKey);
          }
        }
      }

      try {
        const cart = (
          await shopifyClient.request(cartByIdQuery, {
            cartId,
            countryCode: getCountryCode(),
          })
        ).cart;

        if (!cart) {
          localStorage.removeItem(cartIdKey);
          localStorage.removeItem(cartDataKey);
          this.renderEmpty();
          return;
        }

        this.cart = cart;
        localStorage.setItem(cartDataKey, JSON.stringify(cart));
        this.renderCart();
      } catch (error) {
        console.error("Failed to load cart:", error);
      }
    }

    clearLineItems() {
      this.lineItemsContainer.innerHTML = "";
    }

    renderEmpty() {
      this.setAttribute("state", "empty");
      this.clearLineItems();

      this.totalPriceDisplay.removeAttribute("amount");
      this.checkoutButton.setAttribute("disabled", "true");
      this.removeAttribute("checkout-valid");

      const eventCartUpdatedDetail: EventCartUpdatedDetail = { count: 0 };
      document.dispatchEvent(new CustomEvent("cart:updated", { detail: eventCartUpdatedDetail }));
    }

    renderCart() {
      if (!this.cart || !this.cart.lines?.edges?.length) {
        this.renderEmpty();
        return;
      }

      this.setAttribute("state", "loaded");
      this.clearLineItems();

      for (const edge of this.cart.lines.edges) {
        const line = edge.node;
        if (line.__typename !== "CartLine") continue;

        // Clone template
        const clone = this.itemTemplate.content.cloneNode(true) as DocumentFragment;
        const cartLineItemElement = clone.querySelector("cart-line-item") as CartLineItemElement;
        customElements.whenDefined("cart-line-item").then(() => {
          cartLineItemElement.init(line);
        });

        this.lineItemsContainer.appendChild(clone);
      }

      const total = this.cart.cost.totalAmount;
      this.totalPriceDisplay.setAttribute("amount", String(total.amount));
      this.totalPriceDisplay.setAttribute("currency", total.currencyCode);

      if (this.cart.checkoutUrl && this.cart.lines?.edges?.length) {
        this.setAttribute("checkout-valid", "");
      } else {
        this.removeAttribute("checkout-valid");
      }

      const count = this.cart.lines.edges.reduce((sum, edge) => {
        return sum + (edge.node.__typename === "CartLine" ? edge.node.quantity : 0);
      }, 0);
      document.dispatchEvent(new CustomEvent("cart:updated", { detail: { count } }));
    }
  }

  customElements.define("cart-root", CartRootElement);
</script>

<script>
  import type { EventCartUpdated } from "@components/cart/Cart.astro.0.mts";
  import type { OverlayElement } from "@layouts/Overlay.astro.0.mjs";

  const cartCountElements = document.querySelectorAll(
    "[data-cart-count]",
  ) as NodeListOf<HTMLElement>;
  const cartOverlay = document.querySelector(`overlay-root[id="cart"]`) as OverlayElement | null;

  document.addEventListener("product:add-to-cart", () => {
    if (!cartOverlay) throw new Error("Cart overlay element not found");
    cartOverlay.open();
  });

  for (const cartCountElement of cartCountElements) {
    document.addEventListener("cart:updated", (e: Event) => {
      const eventCartUpdated = e as EventCartUpdated;
      cartCountElement.textContent = `(${eventCartUpdated.detail.count})`;
    });
  }
</script>

<style>
  cart-root {
    height: 100%;
  }

  .header {
    margin-bottom: var(--s40);
  }

  .cart-content {
    width: 100%;
    height: 100%;

    display: flex;
    flex-direction: column;
    gap: var(--s40);
  }

  .cart-line-items {
    display: flex;
    flex-direction: column;
    gap: var(--s24);
  }

  .footer {
    margin-top: auto;
  }

  .checkout-button {
    margin-top: var(--s40);
    align-self: flex-start;
  }

  .empty-message {
    display: none;
  }

  cart-root[state="empty"] .empty-message {
    display: block;
  }

  cart-root[state="empty"] .cart-line-items,
  cart-root[state="empty"] [data-cart-total] {
    display: none;
  }

  cart-root:not([checkout-valid]) [data-cart-checkout-button] {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
