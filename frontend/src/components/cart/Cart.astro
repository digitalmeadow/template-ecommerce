---
import PriceDisplay from "@blocks/PriceDisplay.astro";
import QuantitySelector from "@blocks/QuantitySelector.astro";
import CartLineItem from "@components/cart/CartLineItem.astro";
import Overlay from "@layouts/Overlay.astro";
---

<Overlay id="cart" layout="right">
  <cart-root slot="content">
    <!-- BUG: Astro dedup fails to mount native web components when within <template> tags -->
    <div style="display: none">
      <QuantitySelector />
      <PriceDisplay />
    </div>

    <template data-cart-line-template>
      <li>
        <CartLineItem />
      </li>
    </template>

    <ul data-cart-line-items></ul>

    <div data-cart-total>
      <span>Total: <PriceDisplay /></span>
    </div>

    <button data-cart-checkout>Checkout</button>
  </cart-root>
</Overlay>

<script>
  import { shopifyClient } from "shopify/client";
  import { cartByIdQuery } from "shopify/queries/cart";
  import { cartLinesUpdateMutation, cartLinesRemoveMutation } from "shopify/mutations/cart";
  import type { CartFragment } from "shopify/generated/graphql";
  import {
    CART_ID_STORAGE_KEY_SUFFIX,
    CART_DATA_STORAGE_KEY_SUFFIX,
    getStorageKey,
  } from "@lib/shopify/cart";
  import { getCurrency, getCountryCode } from "@lib/shopify/locale";
  import type {
    QuantitySelectorElement,
    EventQuantityChanged,
  } from "@blocks/QuantitySelector.astro.0.mts";

  export type EventCartUpdatedDetail = {
    count: number;
  };
  export type EventCartUpdated = CustomEvent<EventCartUpdatedDetail>;

  class CartRootElement extends HTMLElement {
    private template!: HTMLTemplateElement;
    private lineItemsContainer!: HTMLUListElement;
    private checkoutButton!: HTMLButtonElement;
    private totalPriceDisplay!: HTMLElement;

    private cart: CartFragment | null = null;
    private mutationQueue: Promise<void> = Promise.resolve();

    connectedCallback() {
      this.template = this.querySelector("[data-cart-line-template]")!;
      this.lineItemsContainer = this.querySelector("[data-cart-line-items]")!;
      this.totalPriceDisplay = this.querySelector("[data-cart-total] price-display")!;
      this.checkoutButton = this.querySelector("[data-cart-checkout]")!;

      this.checkoutButton.addEventListener("click", this.onCheckoutClick);
      this.addEventListener("quantity-selector:quantity-changed", this.onQuantityChange);
      document.addEventListener("product:add-to-cart", this.onProductAdded);

      this.loadCart();
    }

    disconnectedCallback() {
      this.checkoutButton.removeEventListener("click", this.onCheckoutClick);
      this.removeEventListener("quantity-selector:quantity-changed", this.onQuantityChange);
      document.removeEventListener("product:add-to-cart", this.onProductAdded);
    }

    onCheckoutClick = (_event: MouseEvent) => {
      if (this.cart?.checkoutUrl) {
        window.location.href = this.cart.checkoutUrl;
      }
    };

    onProductAdded = async () => {
      await this.mutationQueue;
      await this.loadCart();
    };

    onQuantityChange = async (e: Event) => {
      const event = e as EventQuantityChanged;
      const quantitySelector = event.target as QuantitySelectorElement;
      const li = quantitySelector.closest("li") as HTMLLIElement;
      const lineId = li.dataset.lineId!;
      const newQuantity = event.detail.value;
      const cartIdKey = getStorageKey(CART_ID_STORAGE_KEY_SUFFIX);
      const cartId = localStorage.getItem(cartIdKey)!;

      quantitySelector.setUpdatingState(true);

      document.body.style.cursor = "wait";

      this.mutationQueue = this.mutationQueue.then(async () => {
        await shopifyClient.request(cartLinesUpdateMutation, {
          cartId,
          lines: [{ id: lineId, quantity: newQuantity }],
          countryCode: getCountryCode(),
        });
        await this.loadCart(true);
        document.body.style.cursor = "";
      });
      await this.mutationQueue;
    };

    removeCartLineItem = (lineId: string, lineItem: HTMLDivElement) => async () => {
      const cartIdKey = getStorageKey(CART_ID_STORAGE_KEY_SUFFIX);
      const cartId = localStorage.getItem(cartIdKey)!;

      lineItem.setAttribute("data-state", "removing");

      document.body.style.cursor = "wait";

      this.mutationQueue = this.mutationQueue.then(async () => {
        await shopifyClient.request(cartLinesRemoveMutation, {
          cartId,
          countryCode: getCountryCode(),
          lineIds: [lineId],
        });
        await this.loadCart(true);
        document.body.style.cursor = "";
      });
      await this.mutationQueue;
    };

    async loadCart(skipCache = false) {
      const cartIdKey = getStorageKey(CART_ID_STORAGE_KEY_SUFFIX);
      const cartDataKey = getStorageKey(CART_DATA_STORAGE_KEY_SUFFIX);

      const cartId = localStorage.getItem(cartIdKey);
      if (!cartId) {
        this.renderEmpty();
        return;
      }

      if (!skipCache) {
        const cached = localStorage.getItem(cartDataKey);
        if (cached) {
          this.cart = JSON.parse(cached) as CartFragment;
          this.renderCart();
        }
      }

      try {
        const cart = (
          await shopifyClient.request(cartByIdQuery, {
            cartId,
            countryCode: getCountryCode(),
          })
        ).cart;

        if (!cart) {
          localStorage.removeItem(cartIdKey);
          localStorage.removeItem(cartDataKey);
          this.renderEmpty();
          return;
        }

        this.cart = cart;
        localStorage.setItem(cartDataKey, JSON.stringify(cart));
        this.renderCart();
      } catch (error) {
        console.error("Failed to load cart:", error);
      }
    }

    clearLineItems() {
      this.lineItemsContainer.innerHTML = "";
    }

    renderEmpty() {
      this.setAttribute("state", "empty");
      this.clearLineItems();

      this.totalPriceDisplay.removeAttribute("amount");
      this.checkoutButton.setAttribute("disabled", "true");
      this.removeAttribute("checkout-valid");

      const eventCartUpdatedDetail: EventCartUpdatedDetail = { count: 0 };
      document.dispatchEvent(new CustomEvent("cart:updated", { detail: eventCartUpdatedDetail }));
    }

    renderCart() {
      if (!this.cart || !this.cart.lines?.edges?.length) {
        this.renderEmpty();
        return;
      }

      this.setAttribute("state", "loaded");

      this.clearLineItems();

      for (const edge of this.cart.lines.edges) {
        const line = edge.node;
        if (line.__typename !== "CartLine") continue;

        const li = (this.template.content.cloneNode(true) as DocumentFragment)
          .firstElementChild as HTMLLIElement;
        const lineItem = li.querySelector("[data-cart-line-item]") as HTMLDivElement;
        const productTitleElement = lineItem.querySelector(
          "[data-product-title]",
        ) as HTMLSpanElement;
        const productVariantTitleElement = lineItem.querySelector(
          "[data-product-variant-title]",
        ) as HTMLSpanElement;
        const priceDisplay = lineItem.querySelector("[data-price]") as HTMLElement;
        const compareAtPriceDisplay = lineItem.querySelector(
          "[data-price-compare-at]",
        ) as HTMLElement;
        const quantitySelector = lineItem.querySelector("quantity-selector") as HTMLElement;
        const cartLineRemoveButton = lineItem.querySelector(
          "[data-cart-line-remove-button]",
        ) as HTMLButtonElement;

        const variantTitle = line.merchandise?.title;
        const productTitle = line.merchandise?.product?.title;

        const isSingleDefaultVariant =
          variantTitle === "Default Title" &&
          productTitle &&
          line.merchandise?.product?.variants?.edges.length === 1;

        productTitleElement.textContent = productTitle;
        if (!isSingleDefaultVariant) productVariantTitleElement.textContent = variantTitle;

        priceDisplay.setAttribute("amount", String(line.cost.totalAmount.amount ?? 0));
        priceDisplay.setAttribute("currency", line.cost.totalAmount.currencyCode ?? getCurrency());

        // Handle compare-at price
        if (line.merchandise?.compareAtPrice) {
          const compareAtTotal = Number(line.merchandise.compareAtPrice.amount) * line.quantity;
          compareAtPriceDisplay.setAttribute("amount", String(compareAtTotal));
          compareAtPriceDisplay.setAttribute(
            "currency",
            line.merchandise.compareAtPrice.currencyCode ?? getCurrency(),
          );
          compareAtPriceDisplay.style.display = "";
        } else {
          compareAtPriceDisplay.style.display = "none";
        }

        quantitySelector.setAttribute("initial", String(line.quantity));

        cartLineRemoveButton.addEventListener("click", this.removeCartLineItem(line.id, lineItem));

        li.dataset.lineId = line.id;

        this.lineItemsContainer.appendChild(li);
      }

      const total = this.cart.cost.totalAmount;
      this.totalPriceDisplay.setAttribute("amount", String(total.amount));
      this.totalPriceDisplay.setAttribute("currency", total.currencyCode);

      if (this.cart.checkoutUrl && this.cart.lines?.edges?.length) {
        this.setAttribute("checkout-valid", "");
      } else {
        this.removeAttribute("checkout-valid");
      }

      const count = this.cart.lines.edges.reduce((sum, edge) => {
        return sum + (edge.node.__typename === "CartLine" ? edge.node.quantity : 0);
      }, 0);
      document.dispatchEvent(new CustomEvent("cart:updated", { detail: { count } }));
    }
  }

  customElements.define("cart-root", CartRootElement);
</script>

<style>
  cart-root {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 400px;
    background: white;
    display: flex;
    flex-direction: column;
    padding: 2rem;
  }

  cart-root[state="empty"] [data-cart-line-items]::before {
    content: "Your cart is empty.";
    display: block;
  }

  cart-root:not([checkout-valid]) [data-cart-checkout] {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
