---
import QuantitySelector from "../QuantitySelector.astro";
import Price from "../Price.astro";
import CartLineItem from "./CartLineItem.astro";
---

<cart-root>
  <!-- BUG: Astro dedup fails to mount native web components when within <template> tags -->
  <div style="display: none">
    <QuantitySelector />
    <Price />
  </div>

  <template data-cart-line-template>
    <li>
      <CartLineItem />
    </li>
  </template>

  <ul data-cart-line-items></ul>
  <div data-cart-total>
    <span>Total: <Price data-bind-price /></span>
    <button data-cart-checkout>Checkout</button>
  </div>
</cart-root>

<script>
  import { shopifyClient } from "shopify/client";
  import { cartByIdQuery } from "shopify/queries/cart";
  import {
    cartLinesUpdateMutation,
    cartLinesRemoveMutation,
  } from "shopify/mutations/cart";
  import type { CartFragment } from "shopify/generated/graphql";
  import {
    getCountryCode,
    getCurrency,
    getStoredLocale,
  } from "../../lib/locale";

  class CartRootElement extends HTMLElement {
    private template!: HTMLTemplateElement;
    private lineItemsContainer!: HTMLUListElement;
    private checkoutButton!: HTMLButtonElement;
    private totalPriceDisplay!: HTMLElement;

    private cart: CartFragment | null = null;
    private mutationQueue: Promise<void> = Promise.resolve();

    private getStorageKey(suffix: string): string {
      const locale = getStoredLocale();
      const currency = getCurrency();
      return `shopify_${locale}_${currency}_${suffix}`;
    }

    connectedCallback() {
      this.template = this.querySelector("[data-cart-line-template]")!;
      this.lineItemsContainer = this.querySelector("[data-cart-line-items]")!;
      this.totalPriceDisplay = this.querySelector(
        "[data-cart-total] [data-bind-price]"
      )!;
      this.checkoutButton = this.querySelector("[data-cart-checkout]")!;

      // Checkout click
      this.checkoutButton.addEventListener("click", this.onCheckoutClick);

      // Event delegation for child components
      this.addEventListener("quantity-changed", this.onQuantityChange);
      this.addEventListener("click", this.onRemoveClick);

      // Re-render on "add-to-cart"
      document.addEventListener("product:add-to-cart", this.onProductAdded);

      // Load cart initially
      this.loadCart();
    }

    disconnectedCallback() {
      this.checkoutButton.removeEventListener("click", this.onCheckoutClick);
      this.removeEventListener("quantity-changed", this.onQuantityChange);
      this.removeEventListener("click", this.onRemoveClick);
      document.removeEventListener("product:add-to-cart", this.onProductAdded);
    }

    onCheckoutClick = (_event: MouseEvent) => {
      if (this.cart?.checkoutUrl) {
        window.location.href = this.cart.checkoutUrl;
      }
    };

    onProductAdded = async () => {
      // Wait for any queued mutations to finish
      await this.mutationQueue;
      await this.loadCart();
    };

    onQuantityChange = async (e: Event) => {
      const event = e as CustomEvent<{ value: number }>;
      const quantitySelector = event.target as HTMLElement;
      const li = quantitySelector.closest("li") as HTMLLIElement;
      const lineId = li.dataset.lineId!;
      const newQuantity = event.detail.value;
      const cartIdKey = this.getStorageKey("cartId");
      const cartId = localStorage.getItem(cartIdKey)!;

      // Set updating state on the quantity selector
      const selectorElement = quantitySelector as any;
      if (selectorElement.setUpdatingState) {
        selectorElement.setUpdatingState(true);
      }

      // Set document cursor
      document.body.style.cursor = "wait";

      this.mutationQueue = this.mutationQueue.then(async () => {
        const countryCode = getCountryCode();

        await shopifyClient.request(cartLinesUpdateMutation, {
          cartId,
          lines: [{ id: lineId, quantity: newQuantity }],
          countryCode,
        });
        await this.loadCart(true);
        document.body.style.cursor = "";
      });
      await this.mutationQueue;
    };

    onRemoveClick = async (e: Event) => {
      const target = e.target as HTMLElement;
      if (!target.hasAttribute("data-remove-button")) return;

      const removeButton = target as HTMLButtonElement;
      const lineItem = removeButton.parentElement as HTMLDivElement;
      const lineId = removeButton.dataset.lineId!;
      const cartIdKey = this.getStorageKey("cartId");
      const cartId = localStorage.getItem(cartIdKey)!;

      // Set state on line item container
      lineItem.setAttribute("data-state", "removing");

      // Set document cursor
      document.body.style.cursor = "wait";

      this.mutationQueue = this.mutationQueue.then(async () => {
        const countryCode = getCountryCode();
        await shopifyClient.request(cartLinesRemoveMutation, {
          cartId,
          lineIds: [lineId],
          countryCode,
        });
        await this.loadCart(true);
        document.body.style.cursor = "";
      });
      await this.mutationQueue;
    };

    async loadCart(skipCache = false) {
      const cartIdKey = this.getStorageKey("cartId");
      const cartDataKey = this.getStorageKey("cartData");

      const cartId = localStorage.getItem(cartIdKey);
      if (!cartId) {
        this.renderEmpty();
        return;
      }

      // Load from cache first (unless skipped after mutations)
      if (!skipCache) {
        const cached = localStorage.getItem(cartDataKey);
        if (cached) {
          this.cart = JSON.parse(cached) as CartFragment;
          this.renderCart();
        }
      }

      // Fetch fresh
      try {
        const freshCart = (
          await shopifyClient.request(cartByIdQuery, { cartId })
        ).cart;

        if (!freshCart) {
          // Cart no longer exists, clear everything
          localStorage.removeItem(cartIdKey);
          localStorage.removeItem(cartDataKey);
          this.renderEmpty();
          return;
        }

        this.cart = freshCart;
        localStorage.setItem(cartDataKey, JSON.stringify(freshCart));
        this.renderCart();
      } catch (error) {
        console.error("Failed to load cart:", error);
        // Keep showing cached data on error
      }
    }

    clearLineItems() {
      this.lineItemsContainer.innerHTML = "";
    }

    renderEmpty() {
      this.setAttribute("state", "empty");
      this.clearLineItems();

      this.totalPriceDisplay.removeAttribute("amount");
      this.checkoutButton.setAttribute("disabled", "true");
      this.removeAttribute("checkout-valid");
    }

    renderCart() {
      if (!this.cart || !this.cart.lines?.edges?.length) {
        this.renderEmpty();
        return;
      }

      this.setAttribute("state", "loaded");

      this.clearLineItems();

      for (const edge of this.cart.lines.edges) {
        const line = edge.node;
        if (line.__typename !== "CartLine") continue;

        // Clone template
        const li = (this.template.content.cloneNode(true) as DocumentFragment)
          .firstElementChild as HTMLLIElement;
        const lineItem = li.querySelector("[data-line-item]") as HTMLDivElement;
        const productTitleElement = lineItem.querySelector(
          "[data-product-title]"
        ) as HTMLSpanElement;
        const productVariantTitleElement = lineItem.querySelector(
          "[data-product-variant-title]"
        ) as HTMLSpanElement;
        const priceDisplay = lineItem.querySelector(
          "[data-bind-price]"
        ) as HTMLElement;
        const quantitySelector = lineItem.querySelector(
          "quantity-selector"
        ) as HTMLElement;
        const removeButton = lineItem.querySelector(
          "[data-remove-button]"
        ) as HTMLButtonElement;

        // Populate elements
        const variantTitle = line.merchandise?.title;
        const productTitle = line.merchandise?.product?.title;

        const isSingleDefaultVariant =
          variantTitle === "Default Title" &&
          productTitle &&
          line.merchandise?.product?.variants?.edges.length === 1;

        productTitleElement.textContent = productTitle;
        productVariantTitleElement.textContent = isSingleDefaultVariant
          ? ""
          : variantTitle;

        priceDisplay.setAttribute(
          "amount",
          String(line.cost?.totalAmount?.amount ?? 0)
        );
        priceDisplay.setAttribute(
          "currency",
          line.cost?.totalAmount?.currencyCode ?? "USD"
        );

        quantitySelector.setAttribute("initial", String(line.quantity));
        removeButton.dataset.lineId = line.id;

        // Attach line id for event delegation
        li.dataset.lineId = line.id;

        this.lineItemsContainer.appendChild(li);
      }

      // Update total via attribute
      const total = this.cart.cost?.totalAmount;
      this.totalPriceDisplay.setAttribute("amount", String(total.amount));
      this.totalPriceDisplay.setAttribute("currency", total.currencyCode);

      // Set checkout-valid if cart has items and checkout URL exists
      if (this.cart.checkoutUrl && this.cart.lines?.edges?.length) {
        this.setAttribute("checkout-valid", "");
      } else {
        this.removeAttribute("checkout-valid");
      }
    }
  }

  customElements.define("cart-root", CartRootElement);
</script>

<style>
  cart-root[state="empty"] [data-cart-line-items]::before {
    content: "Your cart is empty.";
    display: block;
  }

  cart-root:not([checkout-valid]) [data-cart-checkout] {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
