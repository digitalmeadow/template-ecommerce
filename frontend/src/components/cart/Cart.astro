---
import PriceDisplay from "@blocks/PriceDisplay.astro";
import QuantitySelector from "@blocks/QuantitySelector.astro";
import Overlay from "@layouts/Overlay.astro";
import CartLineItem from "./CartLineItem.astro";
import { sanityClient } from "sanity/client";
import { cartQuery } from "sanity/queries/cart";
import PortableText from "@fields/PortableText.astro";

const cartQueryResult = await sanityClient.request(cartQuery);
const cartData = cartQueryResult.allCart[0];
---

<Overlay id="cart" layout="right" aria-label="Shopping Cart">
  <div class="header" slot="header">
    <h2>Your Cart <span data-cart-count></span></h2>
  </div>

  <aside class="cart" data-cart slot="content">
    <div style="display: none">
      <QuantitySelector />
      <PriceDisplay />
      <CartLineItem />
    </div>

    <template data-cart-line-template>
      <li>
        <CartLineItem />
      </li>
    </template>

    <div class="cart-content">
      <div class="empty-message">
        <PortableText value={cartData.emptyMessageRaw} />
      </div>

      <ul class="cart-line-items" data-cart-line-items></ul>

      <div data-cart-total>
        <span>Total:&nbsp;<PriceDisplay /></span>
      </div>

      <div class="footer">
        <p data-cart-note>
          <PortableText value={cartData.noteRaw} />
        </p>

        <button class="text-link checkout-button" data-cart-checkout-button>Checkout</button>
      </div>
    </div>
  </aside>
</Overlay>

<script>
  import {
    $cart,
    $cartTotal,
    $checkoutUrl,
    $cartLines,
    loadCart,
    updateLineQuantity,
    removeLine,
  } from "@stores/cart";
  import { cartOpen, setCartOpen } from "@stores/ui";
  import type { CartLineItemElement } from "./CartLineItem.astro.0.mts";

  const cartEl = document.querySelector("[data-cart]") as HTMLElement;
  const lineItemsContainer = cartEl?.querySelector("[data-cart-line-items]") as HTMLUListElement;
  const totalPriceDisplay = cartEl?.querySelector("[data-cart-total] price-display") as HTMLElement;
  const checkoutButton = cartEl?.querySelector("[data-cart-checkout-button]") as HTMLButtonElement;
  const itemTemplate = cartEl?.querySelector("[data-cart-line-template]") as HTMLTemplateElement;
  const overlayElement = document.querySelector('overlay-root[id="cart"]') as HTMLElement;

  function handleCheckoutClick() {
    const url = $checkoutUrl.get();
    if (!url) throw new Error("Checkout URL is not available");
    window.location.href = url;
  }

  async function handleQuantityChange(e: Event) {
    const event = e as CustomEvent<{ value: number }>;
    const quantitySelectorElement = event.target as HTMLElement;

    const lineItemEl = quantitySelectorElement.closest("[data-cart] cart-line-item");
    if (!lineItemEl) return;

    const lineItem = lineItemEl as HTMLElement & { line?: { id: string } };
    if (!lineItem.line) return;

    const lineId = lineItem.line.id;
    const newQuantity = event.detail.value;

    quantitySelectorElement.setAttribute("data-updating", "true");
    document.body.style.cursor = "wait";

    try {
      await updateLineQuantity(lineId, newQuantity);
    } catch (error) {
      console.error("Failed to update cart quantity", error);
    } finally {
      document.body.style.cursor = "";
      quantitySelectorElement.removeAttribute("data-updating");
    }
  }

  async function handleLineRemove(e: Event) {
    const event = e as CustomEvent<{ lineId: string }>;
    const { lineId } = event.detail;
    const lineItemEl = event.target as HTMLElement;

    lineItemEl?.setAttribute("data-removing", "true");
    document.body.style.cursor = "wait";

    try {
      await removeLine(lineId);
    } catch (error) {
      console.error("Failed to remove cart line", error);
    } finally {
      document.body.style.cursor = "";
    }
  }

  function clearLineItems() {
    lineItemsContainer.innerHTML = "";
  }

  function renderCart() {
    const cart = $cart.get();
    const lines = $cartLines.get();

    if (!cart || !lines.length) {
      cartEl.dataset.state = "empty";
      clearLineItems();
      totalPriceDisplay.removeAttribute("amount");
      checkoutButton.disabled = true;
      cartEl.removeAttribute("data-checkout-valid");
      return;
    }

    cartEl.dataset.state = "loaded";
    clearLineItems();

    for (const line of lines) {
      const clone = itemTemplate.content.cloneNode(true) as DocumentFragment;
      const cartLineItemElement = clone.querySelector("cart-line-item") as CartLineItemElement;
      customElements.whenDefined("cart-line-item").then(() => {
        cartLineItemElement.init(line);
      });

      lineItemsContainer.appendChild(clone);
    }
  }

  $cart.subscribe(renderCart);
  $cartTotal.subscribe((total: { amount: string; currencyCode: string } | null) => {
    if (total) {
      totalPriceDisplay.setAttribute("amount", String(total.amount));
      totalPriceDisplay.setAttribute("currency", total.currencyCode);
    } else {
      totalPriceDisplay.removeAttribute("amount");
    }
  });
  $checkoutUrl.subscribe((url: string | null) => {
    if (url) {
      cartEl.setAttribute("data-checkout-valid", "");
      checkoutButton.disabled = false;
    } else {
      cartEl.removeAttribute("data-checkout-valid");
      checkoutButton.disabled = true;
    }
  });
  cartOpen.subscribe((isOpen: boolean) => {
    const overlay = overlayElement as unknown as { open?: () => void; close?: () => void };
    if (isOpen) {
      overlay?.open?.();
    } else {
      overlay?.close?.();
    }
  });

  checkoutButton.addEventListener("click", handleCheckoutClick);
  cartEl.addEventListener("quantity-selector:quantity-changed", handleQuantityChange);
  cartEl.addEventListener("cart-line:remove", handleLineRemove);

  overlayElement.addEventListener("overlay:closed", () => {
    setCartOpen(false);
  });

  loadCart();
</script>

<style>
  .cart {
    height: 100%;
  }

  .header {
    margin-bottom: var(--s40);
  }

  .cart-content {
    width: 100%;
    height: 100%;

    display: flex;
    flex-direction: column;
    gap: var(--s40);
  }

  .cart-line-items {
    display: flex;
    flex-direction: column;
    gap: var(--s24);
  }

  .footer {
    margin-top: auto;
  }

  .checkout-button {
    margin-top: var(--s40);
    align-self: flex-start;
  }

  .empty-message {
    display: none;
  }

  [data-cart][data-state="empty"] .empty-message {
    display: block;
  }

  [data-cart][data-state="empty"] .cart-line-items,
  [data-cart][data-state="empty"] [data-cart-total] {
    display: none;
  }

  [data-cart]:not([data-checkout-valid]) [data-cart-checkout-button] {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
