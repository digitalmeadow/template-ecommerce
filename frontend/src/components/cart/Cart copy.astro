---
import CartLineQuantitySelector from "./CartLineQuantitySelector.astro";
---

<div class="cart" data-cart>
  <ul data-cart-items></ul>

  <template data-cart-line-template>
    <li data-cart-line>
      <img data-cart-line-image />
      <span data-cart-line-title></span>

      <CartLineQuantitySelector min={1} />

      <span data-cart-line-price></span>
      <button data-cart-line-remove>Remove</button>
    </li>
  </template>

  <div data-cart-total></div>
  <button data-cart-checkout style="display: none;">Checkout</button>
</div>

<script>
  import { shopifyClient } from "shopify/client";
  import { cartByIdQuery } from "shopify/queries/cart";
  import {
    cartLinesRemoveMutation,
    cartLinesUpdateMutation,
  } from "shopify/mutations/cart";
  import { sanityClient } from "sanity/client";
  import { productThumbnailByHandleQuery } from "sanity/queries/product";
  import { getSanityImageProps } from "../../lib/sanity/image";
  import { selectDocument } from "../../lib/sanity/drafts";
  import { initQuantitySelector } from "../../lib/shopify/quantity";
  import type { CartFragment } from "shopify/generated/graphql";

  async function initialiseCart(root: HTMLElement) {
    const itemsList = root.querySelector(
      "[data-cart-items]"
    ) as HTMLUListElement;
    const totalEl = root.querySelector("[data-cart-total]") as HTMLDivElement;
    const checkoutBtn = root.querySelector(
      "[data-cart-checkout]"
    ) as HTMLButtonElement;
    const cartLineTemplate = root.querySelector(
      "[data-cart-line-template]"
    ) as HTMLTemplateElement;

    if (!itemsList || !totalEl || !checkoutBtn || !cartLineTemplate)
      throw new Error("Cart: missing elements");

    // Cart mutation queue (CRITICAL)
    let mutationQueue = Promise.resolve();

    function runCartMutation(fn: () => Promise<void>) {
      mutationQueue = mutationQueue.then(fn).catch((err) => {
        console.error("[Cart mutation failed]", err);
      });

      return mutationQueue;
    }

    const thumbnailCache: Record<
      string,
      ReturnType<typeof getSanityImageProps>
    > = {};
    try {
      Object.assign(
        thumbnailCache,
        JSON.parse(localStorage.getItem("cartThumbnailCache") || "{}")
      );
    } catch {}

    const formatMoney = (amount: number, currency: string) => {
      const n = Number(amount);
      if (!Number.isFinite(n)) return "";
      try {
        return new Intl.NumberFormat("en-US", {
          style: "currency",
          currency,
        }).format(n);
      } catch {
        return String(n);
      }
    };

    const fetchCart = async (cartId: string) =>
      (await shopifyClient.request(cartByIdQuery, { cartId })).cart;

    const fetchThumbnail = async (handle: string) => {
      try {
        return selectDocument(
          (
            await sanityClient.request(productThumbnailByHandleQuery, {
              handle,
            })
          ).allProduct
        );
      } catch {
        return null;
      }
    };

    const updateThumbnail = async (
      handle: string,
      thumbnailElement: HTMLImageElement
    ) => {
      if (thumbnailCache[handle])
        Object.assign(thumbnailElement, thumbnailCache[handle]);
      const fresh = await fetchThumbnail(handle);
      if (!fresh) return;

      const props = getSanityImageProps({
        sanityImage: fresh.mediaThumbnail?.image,
      });

      thumbnailCache[handle] = props;
      localStorage.setItem(
        "cartThumbnailCache",
        JSON.stringify(thumbnailCache)
      );
      Object.assign(thumbnailElement, props);
    };

    const renderCartLines = async (cart: CartFragment) => {
      itemsList.innerHTML = "";
      if (!cart.lines?.edges?.length) return;

      for (const edge of cart.lines.edges) {
        const line = edge.node;
        if (line.__typename !== "CartLine") continue;

        const fragment = cartLineTemplate.content.cloneNode(
          true
        ) as DocumentFragment;
        const itemEl = fragment.firstElementChild;
        if (!itemEl) continue;

        itemsList.appendChild(itemEl);

        const thumbnailElement = itemEl.querySelector(
          "[data-cart-line-image]"
        ) as HTMLImageElement;
        const titleEl = itemEl.querySelector(
          "[data-cart-line-title]"
        ) as HTMLSpanElement;
        const priceEl = itemEl.querySelector(
          "[data-cart-line-price]"
        ) as HTMLSpanElement;
        const quantitySelectorElement = itemEl.querySelector(
          "cart-line-quantity-selector"
        ) as HTMLElement;
        const removeBtn = itemEl.querySelector(
          "[data-cart-line-remove]"
        ) as HTMLButtonElement;

        titleEl.textContent = line.merchandise?.title ?? "Unknown variant";

        if (line.cost?.totalAmount)
          priceEl.textContent = formatMoney(
            line.cost.totalAmount.amount,
            line.cost.totalAmount.currencyCode
          );

        updateThumbnail(line.merchandise.product.handle, thumbnailElement);

        // initQuantitySelector(quantitySelectorElement, {
        //   initial: line.quantity,
        //   min: 1,
        //   onChange: (quantity) =>
        //     runCartMutation(async () => {
        //       await shopifyClient.request(cartLinesUpdateMutation, {
        //         cartId: cart.id,
        //         lines: [{ id: line.id, quantity }],
        //       });
        //       await renderCart(true);
        //     }),
        // });
        quantitySelectorElement.addEventListener(
          "quantity-selector:value-updated",
          (e) => {
            runCartMutation(async () => {
              await shopifyClient.request(cartLinesUpdateMutation, {
                cartId: cart.id,
                lines: [{ id: line.id, quantity: e.detail.value }],
              });
              await renderCart(true);
            });
          }
        );

        removeBtn.onclick = () =>
          runCartMutation(async () => {
            removeBtn.textContent = "Removing...";
            removeBtn.disabled = true;

            await shopifyClient.request(cartLinesRemoveMutation, {
              cartId: cart.id,
              lineIds: [line.id],
            });

            await renderCart();
          });
      }
    };

    const renderCart = async (skipCache = false) => {
      const cartId = localStorage.getItem("shopifyCartId");
      if (!cartId) {
        itemsList.innerHTML = "<li>Your cart is empty.</li>";
        totalEl.textContent = "";
        checkoutBtn.style.display = "none";
        return;
      }

      const cachedCart = localStorage.getItem("shopifyCartData");
      if (!skipCache && cachedCart) {
        renderCartLines(JSON.parse(cachedCart));
      }

      const freshCart = await fetchCart(cartId);
      if (!freshCart) return;

      localStorage.setItem("shopifyCartData", JSON.stringify(freshCart));
      renderCartLines(freshCart);

      const total = freshCart.cost?.totalAmount;
      totalEl.textContent = total
        ? `Total: ${formatMoney(total.amount, total.currencyCode)}`
        : "";

      if (freshCart.checkoutUrl) {
        checkoutBtn.style.display = "inline-block";
        checkoutBtn.onclick = () =>
          (window.location.href = freshCart.checkoutUrl);
      } else checkoutBtn.style.display = "none";
    };

    renderCart();

    document.addEventListener("product:add-to-cart", async () => {
      await mutationQueue;
      await renderCart();
    });
  }

  const cartElements = document.querySelectorAll("[data-cart]");
  for (const cartElement of cartElements) {
    initialiseCart(cartElement as HTMLElement);
  }
</script>

<style>
  img {
    width: 50px;
    height: 50px;
    object-fit: cover;
  }
</style>
