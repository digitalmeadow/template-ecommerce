---
import { shopifyClient } from "shopify/client";
import { localizationsQuery } from "shopify/queries/localization";
import { LOCALE_CONFIG, getLocaleFromPath } from "../lib/locale";

const currentLocale = getLocaleFromPath(Astro.url.pathname);

// Fetch available locales from Shopify
const { localization } = await shopifyClient.request(localizationsQuery);
const availableCountries = localization.availableCountries;

// Map Shopify countries to our locale config
const localeOptions = Object.entries(LOCALE_CONFIG)
  .filter(([_, config]) =>
    availableCountries.some(
      (country) =>
        country.isoCode === config.country &&
        country.currency.isoCode === config.currency
    )
  )
  .map(([locale, config]) => ({
    locale,
    label: `${config.label} (${config.currency})`,
    path: config.pathPrefix,
  }));
---

<locale-selector data-current={currentLocale}>
  <select aria-label="Select market">
    {
      localeOptions.map((option) => (
        <option
          value={option.locale}
          selected={option.locale === currentLocale}
          data-path={option.path ?? ""}
        >
          {option.label}
        </option>
      ))
    }
  </select>
</locale-selector>

<script>
  import { isValidLocale, type LocaleCode } from "../lib/locale";

  const LOCALE_STORAGE_KEY = "preferred-locale";
  const DEFAULT_LOCALE: LocaleCode = "en-AU";

  class LocaleSelector extends HTMLElement {
    connectedCallback() {
      const select = this.querySelector("select") as HTMLSelectElement;

      // Set initial value from localStorage
      const storedLocale = localStorage.getItem(LOCALE_STORAGE_KEY);
      if (storedLocale && isValidLocale(storedLocale)) {
        select.value = storedLocale;
      }

      select.addEventListener("change", (e) => {
        const target = e.target as HTMLSelectElement;
        const newLocale = target.value;

        // Save preference to localStorage
        localStorage.setItem(LOCALE_STORAGE_KEY, newLocale);

        // Reload page to reinitialize with new locale
        window.location.reload();
      });
    }
  }

  customElements.define("locale-selector", LocaleSelector);
</script>
