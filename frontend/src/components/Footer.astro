---
import PortableText from "../fields/PortableText.astro";
import SanityLink from "../fields/SanityLink.astro";
import { sanityClient } from "../sanity/client";
import type { FooterQueryQuery } from "../sanity/generated/graphql";
import { footerQuery } from "../sanity/queries/footer";
import { selectDocument } from "../sanity/utils/drafts";

const componentQuery: FooterQueryQuery =
  await sanityClient.request(footerQuery);
const footerData = selectDocument(componentQuery.allFooter);
---

<footer id="footer" class:list={[{ hidden: Astro.url.pathname === "/" }]}>
  <div class="row">
    <div class="description">
      <PortableText value={footerData?.textRaw} />
    </div>

    {
      footerData?.navigationItems?.map((navigationItem) => {
        if (!navigationItem?.link) return null;
        return (
          <SanityLink linkData={navigationItem.link}>
            {navigationItem.label}
          </SanityLink>
        );
      })
    }
  </div>
</footer>

<style>
  footer {
    margin-top: var(--s200);
    padding: 0 var(--margin) var(--margin);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    color: var(--color-grey);
  }
</style>
