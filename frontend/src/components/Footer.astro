---
import PortableText from "@fields/PortableText.astro";
import SanityLink from "@fields/SanityLink.astro";
import NewsletterSignup from "@components/NewsletterSignup.astro";
import { sanityClient } from "sanity/client";
import type { FooterQueryQuery } from "sanity/generated/graphql";
import { footerQuery } from "sanity/queries/footer";
import { selectDocument } from "@lib/sanity/drafts";

const componentQuery: FooterQueryQuery = await sanityClient.request(footerQuery);
const footerData = selectDocument(componentQuery.allFooter);
---

<footer class:list={[{ hidden: Astro.url.pathname === "/" }]}>
  <div class="footer-content">
    <PortableText value={footerData.textRaw} />

    <div class="nav">
      {
        footerData.navigationItems?.map((navigationItem) => {
          if (!navigationItem?.link) return null;
          return <SanityLink linkData={navigationItem.link}>{navigationItem.label}</SanityLink>;
        })
      }
    </div>
  </div>

  <NewsletterSignup />
</footer>

<style>
  footer {
    margin-top: var(--s200);
    padding: 0 var(--margin) var(--margin);
    display: flex;
    flex-direction: column;
    gap: var(--s24);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    gap: var(--s24);
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s8);
  }
</style>
