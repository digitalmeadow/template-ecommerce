---
import type { ProductThumbnailShopifySanity } from "../lib/fetches/productShopifySanity";
import SanityMedia from "../fields/SanityMedia.astro";
import { resolveSanityHref } from "../lib/sanity/links";
import PriceDisplay from "./PriceDisplay.astro";

interface Props {
  productData: ProductThumbnailShopifySanity;
}

const { productData }: Props = Astro.props;
---

<a href={resolveSanityHref("product", productData.sanity.shopify!.handle!.current!)}>
  <article
    class="product-thumbnail"
    data-product-thumbnail
    data-product-root
    data-prices={JSON.stringify(productData.pricesPerLocale)}
  >
    <div class="media">
      <SanityMedia mediaData={productData.sanity.mediaThumbnail} layout="cover" />
    </div>
    <h3>{productData.shopify?.title}</h3>
    <div class="price">
      <PriceDisplay />
    </div>
  </article>
</a>

<script>
  import { getStoredLocale, getCurrency } from "../lib/shopify/locale";

  function initialiseProductThumbnail(element: HTMLElement) {
    const productRoot = element.closest("[data-product-root]") as HTMLElement;
    const priceElement = element.querySelector("price-display") as HTMLElement;

    const pricesJson = productRoot.dataset.prices;
    const prices = JSON.parse(pricesJson!);

    function updatePrice() {
      const locale = getStoredLocale();
      const currency = getCurrency();
      const priceData = prices[locale];

      const amounts = priceData.variants.edges.map((edge: any) =>
        parseFloat(edge.node.price.amount)
      );
      const minPrice = Math.min(...amounts);
      const maxPrice = Math.max(...amounts);
      const hasPriceRange = minPrice !== maxPrice;

      priceElement.setAttribute("amount", minPrice.toString());
      priceElement.setAttribute("currency", currency);

      if (hasPriceRange) {
        priceElement.setAttribute("prefix", "from");
      }
    }

    updatePrice();
  }

  const thumbnails = document.querySelectorAll("[data-product-thumbnail]");
  for (const thumbnail of thumbnails) {
    initialiseProductThumbnail(thumbnail as HTMLElement);
  }
</script>

<style>
  .media {
    width: 100%;
    aspect-ratio: 1 / 1;
  }

  .price {
    margin-top: var(--s8);
  }
</style>
