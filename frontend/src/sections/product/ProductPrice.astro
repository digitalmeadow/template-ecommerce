---
interface Props {
  locale?: string;
}

const { locale = "en-US" }: Props = Astro.props;
---

<div class="product-price" data-product-price data-locale={locale}>
  <span data-bind-price></span>
  <span data-bind-compare-at hidden></span>
</div>

<script>
  function formatMoney(amount: number, currencyCode: string, locale: string) {
    const numericAmount = Number(amount);

    if (!Number.isFinite(numericAmount))
      throw new Error("ProductPrice: invalid price amount");

    try {
      return new Intl.NumberFormat(locale, {
        style: "currency",
        currency: currencyCode,
      }).format(numericAmount);
    } catch {
      return `${numericAmount}`;
    }
  }

  function initialiseProductPrice(rootElement: HTMLElement) {
    const productRoot = rootElement.closest(
      "[data-product-root]"
    ) as HTMLElement;
    if (!productRoot)
      throw new Error("ProductPrice: missing [data-product-root]");

    const priceElement = rootElement.querySelector(
      "[data-bind-price]"
    ) as HTMLElement;
    if (!priceElement)
      throw new Error("ProductPrice: missing [data-bind-price]");

    const compareAtElement = rootElement.querySelector(
      "[data-bind-compare-at]"
    ) as HTMLElement;
    if (!compareAtElement)
      throw new Error("ProductPrice: missing [data-bind-compare-at]");

    const locale = rootElement.dataset.locale || "en-US";

    function handleVariantChange(event: CustomEvent) {
      const { price, compareAtPrice } = event.detail;

      if (!price) {
        priceElement.textContent = "";
        compareAtElement.textContent = "";
        compareAtElement.setAttribute("hidden", "");
        return;
      }

      priceElement.textContent = formatMoney(
        price.amount,
        price.currencyCode,
        locale
      );

      if (compareAtPrice) {
        compareAtElement.textContent = formatMoney(
          compareAtPrice.amount,
          compareAtPrice.currencyCode,
          locale
        );
        compareAtElement.removeAttribute("hidden");
      } else {
        compareAtElement.textContent = "";
        compareAtElement.setAttribute("hidden", "");
      }
    }

    if (!productRoot)
      throw new Error("ProductPrice: missing [data-product-root]");

    productRoot.addEventListener(
      "product:variant-change",
      handleVariantChange as EventListener
    );
  }

  const rootElements = document.querySelectorAll("[data-product-price]");
  for (const rootElement of rootElements) {
    initialiseProductPrice(rootElement as HTMLElement);
  }
</script>
