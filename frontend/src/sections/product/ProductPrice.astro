---
import Price from "../../components/Price.astro";
---

<div class="product-price" data-product-price data-locale="en-US">
  <Price variant="compare-at" data-bind-compare-at />
  <Price data-bind-price />
</div>

<script>
  function initialiseProductPrice(rootElement: HTMLElement) {
    const productRoot = rootElement.closest(
      "[data-product-root]"
    ) as HTMLElement;
    if (!productRoot)
      throw new Error("ProductPrice: missing [data-product-root]");

    const priceElement = rootElement.querySelector(
      "[data-bind-price]"
    ) as HTMLElement;
    if (!priceElement)
      throw new Error("ProductPrice: missing [data-bind-price] element");

    const compareAtElement = rootElement.querySelector(
      "[data-bind-compare-at]"
    ) as HTMLElement;

    const locale = rootElement.dataset.locale || "en-US";

    function handleVariantChange(event: CustomEvent) {
      const { price, compareAtPrice } = event.detail;

      if (!price)
        throw new Error("ProductPrice: missing price in variant-change event");

      priceElement.setAttribute("amount", String(price.amount));

      if (compareAtPrice) {
        compareAtElement.setAttribute("amount", String(compareAtPrice.amount));
      } else {
        compareAtElement.removeAttribute("amount");
      }
    }

    productRoot.addEventListener(
      "product:variant-change",
      handleVariantChange as EventListener
    );
  }

  const rootElements = document.querySelectorAll("[data-product-price]");
  for (const rootElement of rootElements) {
    initialiseProductPrice(rootElement as HTMLElement);
  }
</script>
