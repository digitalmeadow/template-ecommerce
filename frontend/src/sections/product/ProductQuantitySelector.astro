---
interface Props {
  initial?: number;
  min?: number;
  max?: number;
}

const { initial = 1, min = 1, max = Infinity }: Props = Astro.props;
---

<div
  class="product-quantity-selector"
  data-product-quantity
  data-initial={initial}
  data-min={min}
  data-max={max}
>
  <button type="button" data-quantity-decrease aria-label="Decrease quantity">
    −
  </button>

  <input
    type="number"
    inputmode="numeric"
    data-quantity-input
    min={min}
    max={max}
    value={initial}
  />

  <button type="button" data-quantity-increase aria-label="Increase quantity">
    +
  </button>
</div>

<script>
  import { initQuantitySelector } from "../../lib/shopify/quantity";

  const rootElements = document.querySelectorAll("[data-product-quantity]");
  for (const rootElement of rootElements) {
    const productRoot = rootElement.closest(
      "[data-product-root]"
    ) as HTMLElement;

    const initial = Number(rootElement.getAttribute("data-initial"));
    const min = Number(rootElement.getAttribute("data-min"));
    const max = Number(rootElement.getAttribute("data-max"));

    initQuantitySelector(rootElement as HTMLElement, {
      initial: initial,
      min: min,
      max: max,
      onChange: (quantity) => {
        if (productRoot) {
          productRoot.dispatchEvent(
            new CustomEvent("product:quantity-change", {
              bubbles: true,
              detail: { quantity },
            })
          );
        }
      },
    });
  }
</script>
