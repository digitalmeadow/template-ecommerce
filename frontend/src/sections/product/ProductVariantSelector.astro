---
import type { ProductShopifySanity } from "@lib/fetches/productShopifySanity";
import { shopifyIdFromGid } from "shopify/utils/ids";

interface Props {
  productData: ProductShopifySanity;
}

const { productData }: Props = Astro.props;

const options = productData.shopify.options || [];
const variants = productData.shopify.variants.edges;
const isSingleDefaultVariant = variants.length === 1 && variants[0].node.title === "Default Title";

// Prepare minimal variant matching data for client-side
export interface Variant {
  id: string;
  selectedOptions: Array<{
    name: string;
    value: string;
  }>;
  availableForSale: boolean;
}

const variantsForMatching: Variant[] = variants.map((edge) => ({
  id: edge.node.id,
  selectedOptions: edge.node.selectedOptions,
  availableForSale: edge.node.availableForSale,
}));

const selectIdSafe = shopifyIdFromGid(productData.shopify.id);
---

<div
  class="variant-selector"
  data-variant-selector
  data-variants={JSON.stringify(variantsForMatching)}
>
  {
    !isSingleDefaultVariant &&
      options.map((option) => {
        const selectId = `${selectIdSafe}-${option.name.toLowerCase()}`;
        return (
          <div>
            <label for={selectId}>{option.name}:</label>
            <select id={selectId} data-option-select data-option-name={option.name}>
              {option.values.map((value) => (
                <option value={value}>{value}</option>
              ))}
            </select>
          </div>
        );
      })
  }
  <input type="hidden" data-variant-id data-product-id={productData.shopify.id} />
</div>

<script>
  export type EventDetailProductVariantChange = {
    variantId: string;
    availableForSale: boolean;
  };
  export type EventProductVariantChange = CustomEvent<EventDetailProductVariantChange>;

  function initialiseVariantSelector(rootElement: Element) {
    const productRoot = rootElement.closest("[data-product-root]") as HTMLElement;
    if (!productRoot) throw new Error("ProductVariantSelector: missing [data-product-root]");

    const optionSelects = Array.from(
      rootElement.querySelectorAll("[data-option-select]"),
    ) as HTMLSelectElement[];
    const variantIdInput = rootElement.querySelector("[data-variant-id]") as HTMLInputElement;

    const variantsJson = (rootElement as HTMLElement).dataset.variants;
    if (!variantsJson) throw new Error("ProductVariantSelector: missing variants data");
    const variants = JSON.parse(variantsJson);

    function getSelectedOptions() {
      return optionSelects.map((select) => ({
        name: select.dataset.optionName!,
        value: select.value,
      }));
    }

    function findMatchingVariant() {
      const selectedOptions = getSelectedOptions();

      const variant = variants.find((v: any) => {
        return selectedOptions.every((selected) =>
          v.selectedOptions.some(
            (vo: any) => vo.name === selected.name && vo.value === selected.value,
          ),
        );
      });

      return variant || null;
    }

    function updateVariantId() {
      const variant = findMatchingVariant();
      if (!variant) return;

      variantIdInput.value = variant.id;

      const detail: EventDetailProductVariantChange = {
        variantId: variant.id,
        availableForSale: variant.availableForSale,
      };
      productRoot.dispatchEvent(
        new CustomEvent("product:variant-change", {
          bubbles: true,
          detail,
        }),
      );
    }

    optionSelects.forEach((select) => {
      select.addEventListener("change", updateVariantId);
    });

    productRoot.addEventListener("product:request-variant-update", () => {
      updateVariantId();
    });

    updateVariantId();
  }

  const rootElements = document.querySelectorAll("[data-variant-selector]");
  for (const rootElement of rootElements) {
    initialiseVariantSelector(rootElement);
  }
</script>
