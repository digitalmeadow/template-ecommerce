---
import type { ProductShopifySanity } from "../../lib/fetches/productShopifySanity";

interface Props {
  productData: ProductShopifySanity;
}

const { productData }: Props = Astro.props;

const selectIdSafe = productData.shopify.id.replace(/[^a-zA-Z0-9_-]/g, "_");
const variantSelectId = `variant-select-${selectIdSafe}`;

const variants = productData.shopify.variants.edges;
const isSingleDefaultVariant =
  variants.length === 1 && variants[0].node.title === "Default Title";
---

<div class="variant-selector" data-variant-selector>
  {
    !isSingleDefaultVariant && (
      <label for={variantSelectId}>Choose a variant</label>
    )
  }

  <select
    id={variantSelectId}
    name="variantId"
    data-variant-select
    data-product-id={productData.shopify.id}
    style={isSingleDefaultVariant ? "display: none;" : undefined}
  >
    {
      variants.map(({ node }) => (
        <option
          value={node.id}
          data-title={node.title}
          data-available={node.availableForSale ? "true" : "false"}
          data-price-amount={node.price?.amount}
          data-price-currency={node.price?.currencyCode}
          data-compare-at-amount={node.compareAtPrice?.amount ?? ""}
          data-compare-at-currency={node.compareAtPrice?.currencyCode ?? ""}
        >
          {node.title}
        </option>
      ))
    }
  </select>
</div>

<script>
  function initialiseVariantSelector(rootElement: Element) {
    const productRoot = rootElement.closest(
      "[data-product-root]"
    ) as HTMLElement;
    if (!productRoot)
      throw new Error("ProductVariantSelector: missing [data-product-root]");

    const selectElement = rootElement.querySelector(
      "[data-variant-select]"
    ) as HTMLSelectElement;
    if (!(selectElement instanceof HTMLSelectElement))
      throw new Error(
        "ProductVariantSelector: expected <select data-variant-select>"
      );

    function selectedVariantDetail() {
      const option = selectElement.selectedOptions[0];
      if (!option)
        throw new Error("ProductVariantSelector: no selected option");

      const priceAmount = option.dataset.priceAmount;
      const priceCurrency = option.dataset.priceCurrency;
      const compareAtAmount = option.dataset.compareAtAmount;
      const compareAtCurrency = option.dataset.compareAtCurrency;

      return {
        productId: selectElement.dataset.productId,
        variantId: option.value,
        title: option.dataset.title ?? option.textContent ?? "",
        available: option.dataset.available === "true",
        price:
          priceAmount && priceCurrency
            ? { amount: priceAmount, currencyCode: priceCurrency }
            : null,
        compareAtPrice:
          compareAtAmount && compareAtCurrency
            ? { amount: compareAtAmount, currencyCode: compareAtCurrency }
            : null,
      };
    }

    function emitVariantChange() {
      if (!productRoot)
        throw new Error("ProductVariantSelector: missing [data-product-root]");

      productRoot.dispatchEvent(
        new CustomEvent("product:variant-change", {
          bubbles: true,
          detail: selectedVariantDetail(),
        })
      );
    }

    selectElement.addEventListener("change", emitVariantChange);
    document.addEventListener("DOMContentLoaded", emitVariantChange);
  }

  const rootElements = document.querySelectorAll("[data-variant-selector]");
  for (const rootElement of rootElements) {
    initialiseVariantSelector(rootElement);
  }
</script>
