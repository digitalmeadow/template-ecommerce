---
import type { ProductShopifySanity } from "../../lib/fetches/productShopifySanity";
import ProductAddToCart from "./ProductAddToCart.astro";
import ProductVariantSelector from "./ProductVariantSelector.astro";
import ProductPrice from "./ProductPrice.astro";
import QuantitySelector from "../../blocks/QuantitySelector.astro";

interface Props {
  productData: ProductShopifySanity;
}

const { productData }: Props = Astro.props;
---

<div class="product-purchase">
  <h1>{productData.shopify?.title}</h1>
  <ProductVariantSelector productData={productData} />
  <ProductPrice />
  <QuantitySelector />
  <ProductAddToCart />
</div>
