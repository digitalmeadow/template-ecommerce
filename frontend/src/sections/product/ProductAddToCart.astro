<div class="product-add-to-cart" data-product-add-to-cart>
  <button type="button" data-add-to-cart-button data-available-for-sale="true"></button>
</div>

<script>
  import { shopifyClient } from "shopify/client";
  import { cartCreateMutation, cartLinesAddMutation } from "shopify/mutations/cart";
  import {
    CART_DATA_STORAGE_KEY_SUFFIX,
    CART_ID_STORAGE_KEY_SUFFIX,
    getStorageKey,
  } from "@lib/shopify/cart";
  import { getCountryCode } from "@lib/shopify/locale";
  import type { EventProductVariantChange } from "@sections/product/ProductVariantSelector.astro";

  async function initialiseProductAddToCart(rootElement: HTMLElement) {
    const productRoot = rootElement.closest("[data-product-root]");
    if (!productRoot) throw new Error("ProductAddToCart: missing [data-product-root]");

    const button = rootElement.querySelector("[data-add-to-cart-button]") as HTMLButtonElement;
    let currentVariantAvailable = true;

    function getCurrentVariantId() {
      if (!productRoot) throw new Error("ProductAddToCart: missing [data-product-root]");

      const variantIdInput = productRoot.querySelector("[data-variant-id]") as HTMLInputElement;
      if (!variantIdInput)
        throw new Error("ProductAddToCart: missing [data-variant-id] inside product root");

      return variantIdInput.value;
    }

    function getCurrentQuantity() {
      if (!productRoot) throw new Error("ProductAddToCart: missing [data-product-root]");

      const quantityInput = productRoot.querySelector(
        "quantity-selector [data-input]",
      ) as HTMLInputElement;
      if (!quantityInput)
        throw new Error("ProductAddToCart: missing quantity-selector inside product root");

      return Number(quantityInput.value);
    }

    async function addToCart(variantId: string, quantity: number) {
      if (!productRoot) throw new Error("ProductAddToCart: missing [data-product-root]");

      if (!variantId) throw new Error("ProductAddToCart: variantId is required");

      if (!Number.isFinite(quantity) || quantity < 1)
        throw new Error("ProductAddToCart: quantity must be at least 1");

      const cartIdKey = getStorageKey(CART_ID_STORAGE_KEY_SUFFIX);
      const cartDataKey = getStorageKey(CART_DATA_STORAGE_KEY_SUFFIX);

      button.disabled = true;
      button.setAttribute("data-loading", "true");
      document.body.style.cursor = "wait";

      try {
        let cartId = localStorage.getItem(cartIdKey);

        let result;

        if (!cartId) {
          const createResponse = await shopifyClient.request(cartCreateMutation, {
            cartInput: {
              lines: [{ merchandiseId: variantId, quantity }],
            },
            countryCode: getCountryCode(),
          });

          result = createResponse.cartCreate;

          if (!result?.cart)
            throw new Error(result?.userErrors?.[0]?.message || "Cart creation failed");

          cartId = result.cart.id;
          localStorage.setItem(cartIdKey, cartId);
          localStorage.setItem(cartDataKey, JSON.stringify(result.cart));
        } else {
          const addResponse = await shopifyClient.request(cartLinesAddMutation, {
            cartId,
            lines: [{ merchandiseId: variantId, quantity }],
            countryCode: getCountryCode(),
          });

          result = addResponse.cartLinesAdd;

          if (!result?.cart)
            throw new Error(result?.userErrors?.[0]?.message || "Adding to cart failed");
        }

        productRoot.dispatchEvent(
          new CustomEvent("product:add-to-cart", {
            bubbles: true,
            detail: { variantId, quantity, cart: result.cart },
          }),
        );
      } catch (error: any) {
        console.error("[ProductAddToCart] Error:", error);
      } finally {
        button.removeAttribute("data-loading");
        button.disabled = !currentVariantAvailable;
        document.body.style.cursor = "";
      }
    }

    function handleVariantChange(event: Event) {
      const eventProductVariantChange = event as EventProductVariantChange;
      const availableForSale = eventProductVariantChange.detail.availableForSale;

      button.setAttribute("data-available-for-sale", String(availableForSale));
      button.disabled = !availableForSale;
    }

    productRoot.addEventListener("product:variant-change", handleVariantChange);

    button.addEventListener("click", async () => {
      if (!currentVariantAvailable) return;
      const variantId = getCurrentVariantId();
      const quantity = getCurrentQuantity();
      await addToCart(variantId, quantity);
    });
  }

  const rootElements = document.querySelectorAll("[data-product-add-to-cart]");
  for (const rootElement of rootElements) {
    initialiseProductAddToCart(rootElement as HTMLElement);
  }
</script>

<style>
  [data-product-add-to-cart] [data-add-to-cart-button]::before {
    content: "Add to Cart";
  }

  [data-product-add-to-cart] [data-add-to-cart-button][data-available-for-sale="false"]::before {
    content: "Sold Out";
  }

  [data-product-add-to-cart] [data-add-to-cart-button][data-available-for-sale="false"] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  [data-product-add-to-cart] [data-add-to-cart-button][data-loading="true"]::before {
    content: "Adding to cart...";
  }
</style>
