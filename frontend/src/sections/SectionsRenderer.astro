---
import type { SectionCollectionOrSectionHeroOrSectionText } from "../sanity/generated/graphql";
import SectionHero from "./SectionHero.astro";
import SectionText from "./SectionText.astro";
import SectionCollection from "./SectionCollection.astro";

interface Props {
  sections:
    | (SectionCollectionOrSectionHeroOrSectionText | null)[]
    | null
    | undefined;
}

const { sections }: Props = Astro.props;
---

{
  sections?.map((section) => {
    if (!section) return null;

    if (section.__typename === "SectionHero") {
      return <SectionHero section={section} />;
    }

    if (section.__typename === "SectionText") {
      return <SectionText section={section} />;
    }

    if (section.__typename === "SectionCollection") {
      return <SectionCollection section={section} />;
    }

    return null;
  })
}
