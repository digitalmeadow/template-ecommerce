---
import type { MuxVideoFragment } from "sanity/generated/graphql";
import { createBlurUp } from "@mux/blurup";

interface Props {
  videoData: MuxVideoFragment | null | undefined;
  layout?: "width" | "height" | "cover" | "contain";
  loading?: "lazy" | "eager";
  mediaId?: string | null;
}

const { videoData, layout = "width", loading = "lazy", mediaId }: Props = Astro.props;

const aspectRatio = videoData?.asset?.data?.aspect_ratio!.replace(":", "/");
const playbackId = videoData?.asset?.playbackId!;
const posterURL = `https://image.mux.com/${playbackId}/thumbnail.jpg?fit_mode=crop&time=0`;

const { imageDataURL } = await createBlurUp(playbackId, {});
---

<script>
  import "@mux/mux-player";
</script>

<div class={`mux-video layout-${layout}`} style=`aspect-ratio: ${aspectRatio};`>
  <img class="mux-video-placeholder" src={imageDataURL} alt="" />

  <mux-player
    class="video"
    data-media-id={mediaId}
    playback-id={videoData?.asset?.playbackId}
    layout={layout}
    loading={loading}
    poster={posterURL}
    autoplay="muted"
    loop
    title={videoData?.asset?.filename}
    min_resolution="720p"
    oncanplay="this.classList.add('loaded')"
  >
  </mux-player>
</div>

<style>
  mux-player {
    --controls: none;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity var(--transition-media-load);
  }

  mux-player.loaded {
    opacity: var(--media-opacity, 1);
  }

  .mux-video {
    position: relative;
  }

  .mux-video-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .layout-width {
    width: 100%;
  }

  .layout-height {
    height: 100%;
  }

  .layout-cover {
    position: absolute;
    top: 50%;
    left: 50%;
    width: auto;
    min-width: 100%;
    min-height: 100%;
    transform: translateX(-50%) translateY(-50%);
    object-fit: cover;
  }

  .layout-contain {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>
