---
import type { Props as $, Mark } from "astro-portabletext/types";
import { Mark as DefaultMark } from "astro-portabletext/components";
import SanityLink from "@fields/SanityLink.astro";

export type Props = $<Mark>;
const props = Astro.props;
---

{
  () => {
    if (props.node.markType === "link" && props.node.markDef) {
      return (
        <SanityLink class:list={"text-link"} linkData={props.node.markDef}>
          <slot />
        </SanityLink>
      );
    }
    return (
      <DefaultMark {...props}>
        <slot />
      </DefaultMark>
    );
  }
}
