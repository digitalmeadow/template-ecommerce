---
import { PortableText as AstroPortableText } from "astro-portabletext";
import Mark from "@fields/portableTextComponents/Mark.astro";

interface Props {
  value: any;
  class?: string | undefined;
}

const { value }: Props = Astro.props;

const components = {
  mark: Mark,
};
---

<AstroPortableText value={value} components={components} />
