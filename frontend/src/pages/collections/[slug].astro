---
import { sanityClient } from "sanity/client";
import PageLayout from "@layouts/PageLayout.astro";
import { collectionsQuery } from "sanity/queries/collection";
import { fetchCollectionShopifySanity } from "@lib/fetches/collectionShopifySanity";
import SectionHero from "@sections/SectionHero.astro";
import ProductThumbnailsGrid from "@sections/product/ProductThumbnailsGrid.astro";

export async function getStaticPaths() {
  const collectionsQueryQuery = await sanityClient.request(collectionsQuery);
  const slugs = collectionsQueryQuery.allCollection.map(
    (collection) => collection.shopify?.handle?.current,
  );
  return slugs.map((slug) => (slug ? { params: { slug } } : null));
}

let { slug } = Astro.params;
const collectionData = await fetchCollectionShopifySanity(slug);
---

<PageLayout metaData={collectionData?.sanity.meta}>
  <SectionHero
    section={{
      __typename: "SectionHero",
      heading: collectionData.shopify.title,
    }}
  />

  <ProductThumbnailsGrid productsData={collectionData.productThumbnails} />
</PageLayout>

<style>
  .grid {
    width: var(--container-width);
    margin: 0 auto;

    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--gutter);
    margin-top: var(--s40);
  }
  @media (max-width: 500px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
