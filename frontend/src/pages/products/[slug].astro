---
import { sanityClient } from "sanity/client";
import PageLayout from "@layouts/PageLayout.astro";
import { fetchProductShopifySanity } from "@lib/fetches/productShopifySanity";
import { productsQuery } from "sanity/queries/product";
import ProductSection from "@sections/product/ProductSection.astro";
import RelatedProductsSection from "@sections/product/RelatedProductsSection.astro";
import type { MetaFragment } from "sanity/generated/graphql";

export async function getStaticPaths() {
  const productsQueryQuery = await sanityClient.request(productsQuery);
  const paths = productsQueryQuery.allProduct
    .filter((product) => product.shopify!.status === "active")
    .map((product) => {
      return {
        params: { slug: product.shopify!.handle!.current! },
      };
    });
  return paths;
}

let { slug } = Astro.params;
const productData = await fetchProductShopifySanity(slug);

// Meta fallbacks
const metaData: MetaFragment = {
  ...productData.sanity?.meta,
  __typename: "Meta",
  title: productData.sanity?.meta?.title || productData.shopify.title,
};
---

<PageLayout metaData={metaData}>
  <ProductSection productData={productData} />
  <RelatedProductsSection productsData={productData.relatedProducts} />
</PageLayout>
